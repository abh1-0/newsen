{
  "name": "newsen",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Newsen — A glassmorphic classroom smartboard dashboard built with Electron + React",
  "author": "",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "package": "npm run build && node scripts/build.js",
    "build:dist": "npm run build && electron-builder --win --publish never",
    "build:publish": "npm run build && electron-builder --win --publish always"
  },
  "dependencies": {
    "@material/web": "^2.4.1",
    "date-fns": "^4.4.0",
    "electron-updater": "^6.8.9",
    "lucide-react": "^1.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "oxlint": "^1.71.0",
    "vite": "^8.1.1",
    "vite-plugin-electron": "^1.1.0",
    "vite-plugin-electron-renderer": "^1.0.0"
  },
  "build": {
    "appId": "com.newsen.app",
    "productName": "Newsen",
    "directories": {
      "output": "dist-installer"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "publish": {
      "provider": "github",
      "owner": "your-github-username",
      "repo": "newsen",
      "private": false
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "Newsen"
    }
  }
}
