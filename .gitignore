# ── Electron builder temp files ──────────────────────────────────────────────────
.cache/
electron-builder-cache/
app-update.yml

# ── Local config overrides (user-specific data) ───────────────────────────────────
# These files are written by the app at runtime — do not commit user data.
# The checked-in versions should always be "blank" defaults.
# src/data/settings.json   ← commit the blank default
# src/data/timetable.json  ← commit as []
# src/data/shortcuts.json  ← commit as []

# ── Misc ─────────────────────────────────────────────────────────────────────────
*.local
*.tgz
*.zip
