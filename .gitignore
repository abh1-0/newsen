# ── Dependencies ────────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ── Build outputs ────────────────────────────────────────────────────────────────
dist/
dist-ssr/
dist-electron/
dist-installer/
out/
build/

# ── Logs ────────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── Environment & secrets ────────────────────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.p12

# ── OS generated ─────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
